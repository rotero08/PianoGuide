---
// src/components/Callout.astro
import Icon from './Icon.astro';

/**
 * ### Callout Component
 * 
 * A styled highlight panel used to emphasize warnings, notes, or tips.
 */
export interface Props {
  /** 
   * The main header title displayed inside the callout block.
   * @default undefined
   * @example title="Important Note"
   */
  title?: string;
  /** 
   * An alternative heading or label for the callout. If both `title` and `label` are provided,
   * they will merge into the header display.
   * @default undefined
   * @example label="Why audiation comes first"
   */
  label?: string; 
  /** 
   * Optional name of an icon (from the `Icon.astro` lookup directory) to display beside the title.
   * @default "none"
   */
  icon?: 'info' | 'target' | 'warning' | 'play-box' | 'link' | 'speed-wall' | 'app-trap' | 'acronym-trap' | 'repeat' | 'moon' | 'retreat' | 'chevron-down' | 'star' | 'map' | 'none'; 
  /** 
   * If set to true, displays a styled left border using the current accent color.
   * @default false
   */
  bordered?: boolean; 
  /** 
   * The background theme style of the callout box.
   * @default "dark"
   */
  bgColor?: 'dark' | 'tint' | 'transparent' | 'none';
  /** 
   * The accent theme color used to style headers and bordered highlights.
   * @default "gold"
   */
  accentColor?: 'gold' | 'rose' | 'none';
  /** 
   * Custom CSS color variable or hex string to style paragraph typography elements inside.
   * @default undefined
   */
  textColor?: string;
}

const { 
  title, 
  label,
  icon,
  bordered = false,
  bgColor = "dark",
  accentColor = "gold",
  textColor
} = Astro.props;

const displayTitle = title || label;

const presetAccents: Record<string, string> = {
  gold: "var(--gold)",
  rose: "var(--rose)",
  none: "transparent"
};
const resolvedAccent = presetAccents[accentColor] || accentColor;

const presetBackgrounds: Record<string, string> = {
  transparent: "transparent",
  none: "transparent",
  tint: accentColor === 'rose' ? "rgba(212, 118, 138, 0.07)" : "rgba(201, 168, 76, 0.07)"
};

const isDefaultBg = bgColor === 'dark';
const isTintBg = bgColor === 'tint';
const resolvedBg = (isDefaultBg || isTintBg) ? undefined : (presetBackgrounds[bgColor] || bgColor);

const containerStyle = {
  ...(resolvedBg && { backgroundColor: resolvedBg }),
  ...(textColor && { color: textColor }),
  ...(bordered ? {
    borderLeftWidth: "4px",
    borderLeftStyle: "solid",
    borderLeftColor: resolvedAccent,
    borderTopWidth: "1px",
    borderTopStyle: "solid",
    borderTopColor: "var(--border-color)",
    borderRightWidth: "1px",
    borderRightStyle: "solid",
    borderRightColor: "var(--border-color)",
    borderBottomWidth: "1px",
    borderBottomStyle: "solid",
    borderBottomColor: "var(--border-color)"
  } : {
    borderLeftWidth: "0px",
    borderTopWidth: "0px",
    borderRightWidth: "0px",
    borderBottomWidth: "0px"
  })
};

const labelStyle = { color: resolvedAccent !== 'transparent' ? resolvedAccent : undefined };
const contentStyle = { ...(textColor && { color: textColor }) };
---

<div class:list={['callout-container', { bordered, tint: isTintBg }, accentColor]} style={containerStyle}>
  {displayTitle && (
    <span class="callout-label" style={labelStyle}>
      {icon && icon !== 'none' && <Icon name={icon} class="callout-svg" />}
      {displayTitle}
    </span>
  )}
  <div class="callout-content" style={contentStyle}>
    <slot />
  </div>
</div>

<style>
  .callout-container {
    border-radius: 0 8px 8px 0;
    padding: 1.5rem;
    margin: 2rem 0;
    box-sizing: border-box;
  }
  .callout-container { background-color: rgba(30, 41, 59, 0.3); }
  .callout-container.tint.gold { background-color: rgba(201, 168, 76, 0.07); }
  .callout-container.tint.rose { background-color: rgba(212, 118, 138, 0.07); }

  :root[data-theme="light"] .callout-container { background-color: rgba(30, 41, 59, 0.08); }
  :root[data-theme="light"] .callout-container.tint.gold { background-color: rgba(201, 168, 76, 0.05); }
  :root[data-theme="light"] .callout-container.tint.rose { background-color: rgba(212, 118, 138, 0.05); }

  .callout-container.bordered { padding: 1.1rem 1.4rem; }
  
  .callout-label {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: 'Space Grotesk', var(--sl-font), sans-serif;
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 0.6rem;
  }

  .callout-label :global(.callout-svg) {
    width: 18px;
    height: 18px;
  }
  
  .callout-content :global(p) {
    margin: 0;
    font-size: 0.98rem;
    color: var(--text-muted);
    line-height: 1.6;
  }
  .callout-content :global(strong) {
    color: var(--text-main);
  }
</style>
