---
// src/components/TrackBlock.astro

/**
 * ### TrackBlock Component
 * 
 * A structured panel representing a specific path or track node in the curriculum.
 * Features custom accent borders, custom badge tags, and styled container spacing.
 */
export interface Props {
  /** The primary title heading text populated inside the track header. */
  title: string;
  /** The text written on the uppercase metadata badge. */
  badge: string;
  /** Theme styling preset applied to left decorative borders and badges. */
  accentColor?: 'gold' | 'rose';
}

const { title, badge, accentColor = 'gold' } = Astro.props;
---
<div class:list={['track-block', accentColor]}>
  <div class="track-top">
    <span class:list={['track-badge', accentColor]}>{badge}</span>
    <h3>{title}</h3>
  </div>
  <div class="track-content">
    <slot />
  </div>
</div>

<style>
  .track-block {
    background: var(--bg-card) !important;
    border: 1px solid var(--border-color) !important;
    border-radius: var(--radius) !important;
    padding: 1.5rem !important;
    box-sizing: border-box !important;
    display: flex !important;
    flex-direction: column !important;
    height: 100% !important;
  }
  
  .track-block.gold {
    border-left: 4px solid var(--gold) !important;
  }
  :root[data-theme="light"] .track-block.gold {
    border-left-color: var(--sl-color-accent) !important;
  }
  .track-block.rose {
    border-left: 4px solid var(--rose) !important;
  }

  .track-top {
    display: flex !important;
    align-items: center !important;
    gap: 0.75rem !important;
    margin-bottom: 1rem !important;
    flex-wrap: wrap !important;
  }

  /* Badge styling */
  .track-badge {
    font-family: 'JetBrains Mono', monospace !important;
    font-size: 0.58rem !important;
    letter-spacing: 0.09em !important;
    text-transform: uppercase !important;
    font-weight: 700 !important;
    padding: 0.28rem 0.55rem !important;
    border-radius: 5px !important;
    display: inline-block !important;
  }
  .track-badge.gold {
    background: rgba(201, 168, 76, 0.15) !important;
    color: var(--gold) !important;
    border: 1px solid rgba(201, 168, 76, 0.3) !important;
  }
  :root[data-theme="light"] .track-badge.gold {
    background: rgba(154, 116, 32, 0.15) !important;
    color: var(--sl-color-accent) !important;
    border-color: rgba(154, 116, 32, 0.3) !important;
  }
  .track-badge.rose {
    background: rgba(212, 118, 138, 0.15) !important;
    color: var(--rose) !important;
    border: 1px solid rgba(212, 118, 138, 0.3) !important;
  }

  /* Header inside cards */
  .track-top h3 {
    font-family: 'Space Grotesk', sans-serif !important;
    font-size: 1.1rem !important;
    margin: 0 !important;
    color: var(--text-main) !important;
    font-weight: 700 !important;
  }

  /* Content slot styling */
  .track-content {
    font-size: 0.92rem !important;
    line-height: 1.6 !important;
    color: var(--text-muted) !important;
    display: flex !important;
    flex-direction: column !important;
    gap: 1rem !important;
    flex-grow: 1 !important;
  }
  .track-content :global(p) {
    margin: 0 !important;
    font-size: inherit !important;
    line-height: inherit !important;
    color: inherit !important;
  }
  .track-content :global(p a) {
    color: var(--gold) !important;
    text-decoration: none !important;
    border-bottom: 1px dotted var(--gold) !important;
    transition: color 0.15s ease, border-color 0.15s ease !important;
  }
  :root[data-theme="light"] .track-content :global(p a) {
    color: var(--sl-color-accent) !important;
    border-bottom-color: var(--sl-color-accent) !important;
  }
  .track-content :global(p a:hover) {
    color: var(--rose) !important;
    border-bottom-color: var(--rose) !important;
  }
  .track-content :global(ul) {
    margin: 0 0 0 1.2rem !important;
    padding: 0 !important;
    list-style-type: disc !important;
    display: flex !important;
    flex-direction: column !important;
    gap: 0.5rem !important;
  }
  .track-content :global(li) {
    font-size: 0.9rem !important;
    line-height: 1.55 !important;
    color: var(--text-muted) !important;
  }
  .track-content :global(li strong) {
    color: var(--text-main) !important;
  }
</style>
