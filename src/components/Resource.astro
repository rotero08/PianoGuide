</style>

<script is:inline>
  (function() {
    function initResourceControls() {
      const checkedStates = JSON.parse(localStorage.getItem('cp-checked-resources') || '{}');
      const pinnedStates = JSON.parse(localStorage.getItem('cp-pinned-resources') || '{}');
      
      const checkableElements = document.querySelectorAll('.res-done-checkbox, .task-checkbox-input');
      checkableElements.forEach(el => {
        const id = el.getAttribute('data-check-id') || el.id;
        if (!id) return;

        if (id in checkedStates) {
          el.checked = checkedStates[id];
        } else {
          el.checked = false;
        }

        const parentRow = el.closest('.resource-row-container, .task-row-container, .uv-bench-item');
        if (parentRow) {
          if (el.checked) {
            parentRow.classList.add('done');
            if (el.classList.contains('res-done-checkbox')) el.classList.add('checked');
          } else {
            parentRow.classList.remove('done');
            if (el.classList.contains('res-done-checkbox')) el.classList.remove('checked');
          }
        }

        if (!el.hasAttribute('data-listener-bound')) {
          el.setAttribute('data-listener-bound', 'true');
          el.addEventListener('change', (e) => {
            const targetCheckbox = e.target;
            const elementId = targetCheckbox.getAttribute('data-check-id') || targetCheckbox.id;
            const newState = targetCheckbox.checked;

            const currentStates = JSON.parse(localStorage.getItem('cp-checked-resources') || '{}');
            currentStates[elementId] = newState;
            localStorage.setItem('cp-checked-resources', JSON.stringify(currentStates));

            document.querySelectorAll(`[data-check-id="${elementId}"], #${elementId}`).forEach(item => {
              const itemParent = item.closest('.resource-row-container, .task-row-container, .uv-bench-item');
              if (itemParent) {
                if (newState) {
                  itemParent.classList.add('done');
                  if (item.classList.contains('res-done-checkbox')) item.classList.add('checked');
                } else {
                  itemParent.classList.remove('done');
                  if (item.classList.contains('res-done-checkbox')) item.classList.remove('checked');
                }
                item.checked = newState;
              }
            });
            window.dispatchEvent(new CustomEvent('cp-resource-state-changed', { detail: { id: elementId, checked: newState } }));
          });
        }
      });

      const pinButtons = document.querySelectorAll('.res-pin-toggle-btn, .bench-pin-btn');
      pinButtons.forEach(btn => {
        const id = btn.getAttribute('data-pin-id');
        if (!id) return;

        const isPinned = !!pinnedStates[id];
        const parentItem = btn.closest('.resource-row-container, .uv-bench-item');
        
        if (isPinned) {
          btn.classList.add('active');
          if (parentItem) parentItem.setAttribute('data-pinned', 'true');
        } else {
          btn.classList.remove('active');
          if (parentItem) parentItem.setAttribute('data-pinned', 'false');
        }

        if (!btn.hasAttribute('data-listener-bound')) {
          btn.setAttribute('data-listener-bound', 'true');
          btn.addEventListener('click', (e) => {
            e.stopPropagation();
            const elementId = btn.getAttribute('data-pin-id');
            const currentPinnedStates = JSON.parse(localStorage.getItem('cp-pinned-resources') || '{}');
            const newState = !currentPinnedStates[elementId];
            currentPinnedStates[elementId] = newState;
            localStorage.setItem('cp-pinned-resources', JSON.stringify(currentPinnedStates));

            document.querySelectorAll(`[data-pin-id="${elementId}"]`).forEach(itemBtn => {
              const itemParent = itemBtn.closest('.resource-row-container, .uv-bench-item');
              if (newState) {
                itemBtn.classList.add('active');
                if (itemParent) itemParent.setAttribute('data-pinned', 'true');
              } else {
                itemBtn.classList.remove('active');
                if (itemParent) itemParent.setAttribute('data-pinned', 'false');
              }
            });
            window.dispatchEvent(new CustomEvent('cp-resource-pin-changed', { detail: { id: elementId, pinned: newState } }));
          });
        }
      });
    }

    initResourceControls();
    window.addEventListener('cp-rebind-listeners', initResourceControls);
    document.addEventListener('astro:page-load', initResourceControls);
  })();
</script>
