---
// src/components/Bibliography.astro
import { getCitationData } from '../utils/citationScanner';

const { backlinks, numToSlug, slugToNumber } = await getCitationData();
const bibliographyId = `bib-${Math.random().toString(36).substring(2, 11)}`;
---

<div id={bibliographyId} class="bibliography-container" data-backlinks={JSON.stringify(backlinks)} data-num-to-slug={JSON.stringify(numToSlug)} data-slug-to-number={JSON.stringify(slugToNumber)}>
  <slot />
</div>

<style>
  .bibliography-container {
    background-color: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius);
    padding: 1.2rem 1.6rem;
    margin: 1.5rem 0;
  }

  .bibliography-container :global(ul) {
    list-style: none !important;
    margin: 0 !important;
    padding: 0 !important;
    counter-reset: bib-counter;
    display: block !important;
  }

  @media (min-width: 768px) {
    .bibliography-container :global(ul) {
      column-count: 2 !important;
      column-gap: 2rem !important;
    }
  }

  .bibliography-container :global(li) {
    margin: 0 !important;
    padding: 0 !important;
    counter-increment: bib-counter;
    position: relative !important;
    padding-left: 2.4rem !important; 
    font-size: 0.9rem !important;
    line-height: 1.6 !important;
    margin-bottom: 0.5rem !important;
    color: var(--text-muted) !important;
    scroll-margin-top: 6rem;
    break-inside: avoid-column !important;
    -webkit-column-break-inside: avoid !important;
    page-break-inside: avoid !important;
  }

  .bibliography-container :global(li:last-child) {
    margin-bottom: 0 !important;
  }

  /* Numbered Brackets */
  .bibliography-container :global(li::before) {
    content: "[" counter(bib-counter) "]" !important;
    position: absolute !important;
    left: 0 !important;
    width: 2rem !important;
    white-space: nowrap !important;
    text-align: right !important;
    font-family: var(--sl-font-mono) !important;
    font-size: 0.85rem !important;
    font-weight: 700 !important;
    color: var(--gold) !important;
  }

  :root[data-theme="light"] .bibliography-container :global(li::before) {
    color: var(--sl-color-accent) !important;
  }

  .bibliography-container :global(li strong) {
    color: var(--text-main) !important;
  }

  /* Backlinks styling */
  .bibliography-container :global(.backlink-span) {
    margin-right: 0.5rem !important;
    font-family: var(--sl-font-mono) !important;
    font-size: 0.85rem !important;
    font-weight: 700 !important;
    display: inline-block !important;
  }
  
  .bibliography-container :global(.backlink-arrow),
  .bibliography-container :global(.backlink-letter) {
    color: var(--gold) !important;
    text-decoration: none !important;
    transition: color 0.15s ease !important;
  }
  :root[data-theme="light"] .bibliography-container :global(.backlink-arrow),
  :root[data-theme="light"] .bibliography-container :global(.backlink-letter) {
    color: var(--sl-color-accent) !important;
  }
  
  .bibliography-container :global(.backlink-arrow-text) {
    color: var(--sl-color-gray-1) !important;
    opacity: 0.45;
  }
  
  .bibliography-container :global(.backlink-arrow:hover),
  .bibliography-container :global(.backlink-letter:hover) {
    text-decoration: underline !important;
    color: var(--gold-light) !important;
  }

  /* Target-flash Wikipedia effect */
  @keyframes target-flash {
    0% {
      background-color: var(--sl-color-accent-low);
      box-shadow: 0 0 0 6px var(--sl-color-accent-low);
      border-radius: 4px;
    }
    100% {
      background-color: transparent;
      box-shadow: 0 0 0 0 transparent;
    }
  }

  .bibliography-container :global(li:target) {
    animation: target-flash 2.5s cubic-bezier(0.25, 1, 0.5, 1);
  }
</style>
