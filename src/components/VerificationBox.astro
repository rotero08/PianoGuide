---
// src/components/VerificationBox.astro

export interface Props {
  trackId: string;
  title: string;
  subtitle?: string;
  levelInfo?: string;
  slot?: string;
}

const { trackId, title, subtitle, levelInfo } = Astro.props;
---
<div class="verification-outer-container">
  <div class="verification-header-box">
    <div class="vh-header-top-row">
      <h2 class="vh-title-text">{title}</h2>
      <div class="vh-right-content">
        {levelInfo && <span class="vh-level-badge">{levelInfo}</span>}
        <div class="vh-progress-bar-wrapper">
          <div class="vh-bar-bg">
            <div class="vh-bar-fg" id={`${trackId}-bar`}></div>
          </div>
          <span class="vh-pct-label" id={`${trackId}-pct`}>0%</span>
        </div>
      </div>
    </div>
    {subtitle && <p class="vh-subtitle-text">{subtitle}</p>}
  </div>
  
  <div class="verification-body-content">
    <slot />
  </div>
</div>

<style>
  .verification-outer-container {
    background: var(--bg-card) !important;
    border: 1px solid var(--border-color) !important;
    border-left: 4px solid var(--gold) !important;
    border-radius: var(--radius) !important;
    padding: 1.8rem !important;
    margin: 2.5rem 0 !important;
    box-sizing: border-box !important;
  }
  :root[data-theme="light"] .verification-outer-container {
    border-left-color: var(--sl-color-accent) !important;
  }

  .verification-header-box {
    display: flex !important;
    flex-direction: column !important;
    border-bottom: 1px solid var(--border-color) !important;
    padding-bottom: 1.2rem !important;
    margin-bottom: 1.5rem !important;
    gap: 0.35rem !important; /* Clean space between top row and subtitle */
    width: 100% !important;
  }

  /* Flex row aligning the title and right-hand tracking metrics on the exact same plane */
  .vh-header-top-row {
    display: flex !important;
    justify-content: space-between !important;
    align-items: center !important; /* Perfect vertical alignment */
    width: 100% !important;
    flex-wrap: wrap !important;
    gap: 1.5rem !important;
  }

  .vh-title-text {
    font-family: 'Space Grotesk', sans-serif !important;
    font-size: 1.25rem !important;
    font-weight: 700 !important;
    color: var(--text-main) !important;
    margin: 0 !important;
    line-height: 1.2 !important;
  }

  .vh-subtitle-text {
    font-size: 0.88rem !important;
    color: var(--text-muted) !important;
    margin: 0 !important;
    line-height: 1.4 !important;
  }

  .vh-right-content {
    display: flex !important;
    align-items: center !important; /* Centered internally on the right metrics line */
    gap: 1.25rem !important;
  }

  .vh-level-badge {
    font-family: 'Space Grotesk', var(--sl-font), sans-serif !important;
    font-size: 1rem !important; /* Custom 1rem scale */
    color: var(--text-main) !important;
    font-weight: 500 !important;
    letter-spacing: -0.01em !important;
    line-height: 1 !important;
  }

  .vh-progress-bar-wrapper {
    display: flex !important;
    align-items: center !important;
    gap: 0.6rem !important;
    min-width: 140px !important;
  }

  .vh-bar-bg {
    flex-grow: 1 !important;
    height: 6px !important; /* Sleek, thin progress track */
    background-color: rgba(255, 255, 255, 0.1) !important;
    border-radius: 999px !important;
    overflow: hidden !important;
  }
  :root[data-theme="light"] .vh-bar-bg {
    background-color: rgba(0, 0, 0, 0.08) !important;
  }

  .vh-bar-fg {
    height: 100% !important;
    width: 0%;
    background-color: var(--gold) !important;
    border-radius: 999px !important;
    transition: width 0.5s ease-out !important;
  }
  :root[data-theme="light"] .vh-bar-fg {
    background-color: var(--sl-color-accent) !important;
  }

  .vh-pct-label {
    font-family: 'Space Grotesk', var(--sl-font), sans-serif !important;
    font-size: 1rem !important; /* Custom 1rem scale */
    color: var(--gold) !important;
    font-weight: 600 !important;
    min-width: 32px !important;
    text-align: right !important;
    line-height: 1 !important;
  }
  :root[data-theme="light"] .vh-pct-label {
    color: var(--sl-color-accent) !important;
  }

  .verification-body-content :global(h3) {
    font-family: 'Space Grotesk', sans-serif !important;
    font-size: 0.72rem !important;
    font-weight: 700 !important;
    letter-spacing: 0.08em !important;
    text-transform: uppercase !important;
    margin-top: 0 !important;
    margin-bottom: 0.85rem !important;
    color: var(--rose) !important;
  }
</style>
