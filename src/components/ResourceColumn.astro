---
// src/components/ResourceColumn.astro

export interface Props {
  id: 'technique' | 'reading';
  title: string;
  subtitle?: string;
  accentColor?: 'gold' | 'rose';
  slot?: string;
}

const { id, title, subtitle, accentColor = 'gold' } = Astro.props;
---

<div class:list={['res-column-wrapper', id, accentColor]} id={id}>
  <div class="res-column-header">
    <div class="res-title-box">
      {id === 'technique' ? (
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="col-header-svg">
          <path d="M18 11V6a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v5M14 10V4a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v8M10 10.5V5.5a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v9M6 13V9a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v6a10 10 0 0 0 10 10h1a10 10 0 0 0 10-10v-4" />
        </svg>
      ) : (
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="col-header-svg">
          <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
          <circle cx="12" cy="12" r="3" />
        </svg>
      )}
      <h3>{title}</h3>
      {id === 'reading' && <span class="res-reading-tag-meta">THE EYES · HANDS-TOGETHER</span>}
    </div>
    
    {subtitle && <p class="res-column-subtitle" set:html={subtitle}></p>}

    <div class="column-track-progress">
      <div class="ct-progress-bar-bg">
        <div class="ct-progress-bar-fg" id={`col-bar-${id}`}></div>
      </div>
      <span class="ct-progress-text" id={`col-pct-${id}`}>0/0 done</span>
    </div>
  </div>

  <div class="res-list-container">
    <slot />
  </div>
</div>

<style>
  .res-column-wrapper {
    background-color: var(--bg-card) !important;
    border: 1px solid var(--border-color) !important;
    border-radius: var(--radius) !important;
    padding: 1.6rem !important;
    box-sizing: border-box !important;
    display: flex !important;
    flex-direction: column !important;
    height: 100% !important;
  }
  .res-column-wrapper.gold {
    border-top: 3px solid var(--gold) !important;
  }
  :root[data-theme="light"] .res-column-wrapper.gold {
    border-top-color: var(--sl-color-accent) !important;
  }
  .res-column-wrapper.rose {
    border-top: 3px solid var(--rose) !important;
  }
  .res-column-header {
    margin-bottom: 0.3rem !important;
  }
  .res-title-box {
    display: flex !important;
    align-items: center !important;
    gap: 0.55rem !important;
    margin-bottom: 0.45rem !important;
    flex-wrap: wrap !important;
  }
  .res-title-box h3 {
    margin: 0 !important;
    font-family: 'Space Grotesk', sans-serif !important;
    font-size: 1.15rem !important;
    color: var(--text-main) !important;
    font-weight: 700 !important;
    line-height: 1.2 !important;
  }
  .col-header-svg {
    width: 18px !important;
    height: 18px !important;
    flex-shrink: 0 !important;
  }
  .gold .col-header-svg { color: var(--gold) !important; }
  :root[data-theme="light"] .gold .col-header-svg { background-color: var(--sl-color-accent) !important; }
  .rose .col-header-svg { background-color: var(--rose) !important; }
  .res-reading-tag-meta {
    font-family: 'JetBrains Mono', monospace !important;
    font-size: 0.58rem !important;
    color: var(--rose) !important;
    letter-spacing: 0.08em !important;
    margin-left: 0.35rem !important;
  }
  .res-column-subtitle {
    font-size: 0.88rem !important;
    line-height: 1.55 !important;
    color: var(--text-muted) !important;
    margin: 0 0 1rem 0 !important;
  }
  .res-column-subtitle :global(a) {
    color: var(--gold) !important;
    text-decoration: underline !important;
  }
  :root[data-theme="light"] .res-column-subtitle :global(a) {
    color: var(--sl-color-accent) !important;
  }
  .column-track-progress {
    display: flex !important;
    align-items: center !important;
    gap: 0.75rem !important;
    margin-top: 0.85rem !important;
  }
  .ct-progress-bar-bg {
    width: 60px !important;
    height: 5px !important;
    background-color: rgba(128, 128, 128, 0.2) !important;
    border-radius: 3px !important;
    overflow: hidden !important;
    flex-shrink: 0 !important;
  }
  .ct-progress-bar-fg {
    height: 100% !important;
    width: 0%;
    border-radius: 3px !important;
    transition: width 0.3s ease-out !important;
  }
  .gold .ct-progress-bar-fg { background-color: var(--gold) !important; }
  :root[data-theme="light"] .gold .ct-progress-bar-fg { background-color: var(--sl-color-accent) !important; }
  .rose .ct-progress-bar-fg { background-color: var(--rose) !important; }
  .ct-progress-text {
    font-family: 'JetBrains Mono', monospace !important;
    font-size: 0.68rem !important;
    color: var(--text-muted) !important;
    white-space: nowrap !important;
    font-weight: 700 !important;
  }
  .res-list-container {
    display: flex !important;
    flex-direction: column !important;
  }
</style>

<script is:inline define:vars={{ id }}>
  (function() {
    function updateColumnPercentages() {
      const column = document.getElementById(id);
      if (!column) return;

      const listContainer = column.querySelector('.res-list-container');
      if (!listContainer) return;

      // Select resources that are actively in the main list (excluding alternatives inside the accordion)
      const rows = Array.from(listContainer.querySelectorAll('.resource-row-container')).filter(row => {
        return !row.closest('.alternatives-list-container');
      });
      const total = rows.length;

      let completed = 0;
      const checkedStates = JSON.parse(localStorage.getItem('cp-checked-resources') || '{}');

      rows.forEach(row => {
        const resId = row.getAttribute('data-res-id');
        if (checkedStates[resId]) {
          completed++;
        }
      });

      const bar = document.getElementById(`col-bar-${id}`);
      const label = document.getElementById(`col-pct-${id}`);

      if (label) {
        label.textContent = `${completed}/${total} done`;
      }
      if (bar) {
        const pct = total > 0 ? (completed / total) * 100 : 0;
        bar.style.width = `${pct}%`;
      }
    }

    function syncAlternatives() {
      const column = document.getElementById(id);
      if (!column) return;

      const listContainer = column.querySelector('.res-list-container');
      if (!listContainer) return;

      const altBox = column.querySelector('.alternatives-wrapper');
      const altContainer = column.querySelector('.alternatives-list-container');
      if (!altContainer) return;

      const pinnedStates = JSON.parse(localStorage.getItem('cp-pinned-resources') || '{}');
      const alternatives = column.querySelectorAll('.resource-row-container[data-is-alternative="true"]');

      // Tag each element with its initial location on the very first execution pass
      alternatives.forEach(alt => {
        if (!alt.hasAttribute('data-initial-parent')) {
          const startedInAlt = alt.closest('.alternatives-list-container') !== null;
          alt.setAttribute('data-initial-parent', startedInAlt ? 'alt' : 'main');
        }
      });

      let pinnedCount = 0;
      const totalAlts = alternatives.length;

      alternatives.forEach(alt => {
        const resId = alt.getAttribute('data-res-id');
        const initialParent = alt.getAttribute('data-initial-parent');

        const hasUserSetting = pinnedStates.hasOwnProperty(resId);
        const isPinned = hasUserSetting 
          ? (pinnedStates[resId] === true || pinnedStates[resId] === 'true')
          : (initialParent === 'main'); // Default main items are pinned on load, alternatives are not

        if (isPinned) {
          if (initialParent === 'alt') {
            pinnedCount++;
          }
          if (altBox && alt.parentElement !== listContainer) {
            listContainer.insertBefore(alt, altBox);
          } else if (!altBox && alt.parentElement !== listContainer) {
            listContainer.appendChild(alt);
          }
          alt.style.removeProperty('display');
        } else {
          if (alt.parentElement !== altContainer) {
            altContainer.appendChild(alt);
          }
        }
      });

      // SORT ALTERNATIVES CONTAINER: Bubble recommended items (data-is-recommended="true") directly to the top of the unpinned list
      const altChildren = Array.from(altContainer.querySelectorAll('.resource-row-container'));
      altChildren.sort((a, b) => {
        const aRec = a.getAttribute('data-is-recommended') === 'true';
        const bRec = b.getAttribute('data-is-recommended') === 'true';
        if (aRec && !bRec) return -1;
        if (!aRec && bRec) return 1;
        
        // Secondary stable sort sorting alphabetically by id
        const aId = a.getAttribute('data-res-id') || '';
        const bId = b.getAttribute('data-res-id') || '';
        return aId.localeCompare(bId);
      });
      // Re-append sorted children back into altContainer to update actual physical DOM ordering
      altChildren.forEach(child => altContainer.appendChild(child));

      if (altBox) {
        const defaultAlts = Array.from(alternatives).filter(alt => alt.getAttribute('data-initial-parent') === 'alt');
        if (pinnedCount === defaultAlts.length && defaultAlts.length > 0) {
          altBox.style.setProperty('display', 'none', 'important');
        } else {
          altBox.style.removeProperty('display');
        }
      }

      const allRows = listContainer.querySelectorAll('.resource-row-container');
      allRows.forEach(row => row.classList.remove('last-visible'));

      const visibleMainRows = Array.from(allRows).filter(row => {
        if (row.closest('.alternatives-list-container')) return false;
        return row.style.display !== 'none';
      });
      if (visibleMainRows.length > 0) {
        visibleMainRows[visibleMainRows.length - 1].classList.add('last-visible');
      }

      updateColumnPercentages();
      
      // Notify the Alternatives box to sync its own progress bars
      window.dispatchEvent(new CustomEvent('cp-alternatives-synced'));
    }

    function initColumn() {
      const column = document.getElementById(id);
      if (!column) return;

      column.__syncAlternatives = syncAlternatives;
      column.__updateColumnPercentages = updateColumnPercentages;

      syncAlternatives();
      updateColumnPercentages();
    }

    if (!window.__globalPianoColListeners) {
      window.__globalPianoColListeners = true;
      window.addEventListener('cp-resource-pin-changed', () => {
        document.querySelectorAll('.res-column-wrapper').forEach(col => {
          if (typeof col.__syncAlternatives === 'function') col.__syncAlternatives();
        });
      });
      window.addEventListener('cp-resource-state-changed', () => {
        document.querySelectorAll('.res-column-wrapper').forEach(col => {
          if (typeof col.__updateColumnPercentages === 'function') col.__updateColumnPercentages();
        });
      });
    }

    initColumn();
    document.addEventListener('astro:page-load', initColumn);
  })();
</script>
