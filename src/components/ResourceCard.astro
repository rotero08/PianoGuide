---
interface Props {
  category: 'acoustics' | 'pedagogy' | 'theory';
  title: string;
  link: string;
  isPaid?: boolean;
}

const { category, title, link, isPaid = false } = Astro.props;

const categoryLabels: Record<string, string> = {
  acoustics: "Acoustics & DSP",
  pedagogy: "Piano Manuals & Pedagogy",
  theory: "Music Theory & Cognition"
};

const categoryLabel = categoryLabels[category] || category;
const badgeTip = isPaid ? "Paid book." : "Free online resource.";
---
<div class="blueprint-card" data-category={category}>
  <div class="blueprint-meta-row">
    <span class="badge-accent">{categoryLabel}</span>
    {isPaid ? (
      <span class="badge-warning" data-tip={badgeTip}>Paid</span>
    ) : (
      <span class="badge-success" data-tip={badgeTip}>Free</span>
    )}
  </div>
  <a href={link} target="_blank" rel="noopener" class="blueprint-title">
    {title}
  </a>
  <div class="blueprint-desc">
    <slot />
  </div>
</div>

<style>
  .blueprint-card {
    background-color: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius);
    padding: 1.4rem !important; /* Original legacy padding */
    display: flex !important;
    flex-direction: column !important;
    justify-content: flex-start !important; /* Standardizes top alignment across rows */
    gap: 0.5rem !important; /* Tight, uniform gap matching the original design */
    transition: transform 0.2s ease, border-color 0.2s ease;
    box-sizing: border-box !important;
    height: 100% !important; /* Forces cards to stretch to the equal height of the grid cell track */
  }
  
  .blueprint-card:hover {
    transform: translateY(-2px);
    border-color: var(--gold);
  }
  
  :root[data-theme="light"] .blueprint-card:hover {
    border-color: var(--sl-color-accent);
  }
  
  .blueprint-meta-row {
    display: flex !important;
    flex-wrap: wrap !important;
    gap: 0.4rem !important;
    margin: 0 !important;
    padding: 0 !important;
  }
  
  .blueprint-title {
    font-weight: 700 !important;
    color: var(--text-main) !important;
    font-size: 1.02rem !important;
    text-decoration: none !important;
    display: inline-block !important;
    line-height: 1.35 !important;
    margin: 0 !important;
    padding: 0 !important;
    transition: color 0.15s ease;
  }
  
  .blueprint-title:hover {
    color: var(--gold) !important;
  }
  
  :root[data-theme="light"] .blueprint-title:hover {
    color: var(--sl-color-accent);
  }
  
  .blueprint-desc {
    font-size: 0.88rem !important;
    color: var(--text-muted) !important;
    margin: 0 !important;
    padding: 0 !important;
    line-height: 1.45 !important;
  }

  /* Robust reset for any nested paragraph tags compiled by MDX */
  .blueprint-desc :global(p) {
    margin: 0 !important;
    padding: 0 !important;
    font-size: inherit !important;
    line-height: inherit !important;
    color: inherit !important;
  }

  /* Badges */
  .badge-accent {
    background-color: rgba(201, 168, 76, 0.13);
    color: var(--gold);
    border: 1px solid rgba(201, 168, 76, 0.3);
    padding: 0.15rem 0.45rem;
    border-radius: 4px;
    font-size: 0.62rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-family: 'JetBrains Mono', monospace;
  }
  
  :root[data-theme="light"] .badge-accent {
    background-color: rgba(154, 116, 32, 0.13);
    color: var(--sl-color-accent);
    border-color: rgba(154, 116, 32, 0.3);
  }
  
  .badge-warning {
    background-color: rgba(212, 118, 138, 0.13);
    color: var(--rose);
    border: 1px solid rgba(212, 118, 138, 0.3);
    padding: 0.15rem 0.45rem;
    border-radius: 4px;
    font-size: 0.62rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-family: 'JetBrains Mono', monospace;
  }
  
  .badge-success {
    background-color: rgba(111, 181, 138, 0.13);
    color: var(--badge-free);
    border: 1px solid rgba(111, 181, 138, 0.3);
    padding: 0.15rem 0.45rem;
    border-radius: 4px;
    font-size: 0.62rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-family: 'JetBrains Mono', monospace;
  }
</style>
