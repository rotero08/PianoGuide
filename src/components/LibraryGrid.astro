---
// src/components/LibraryGrid.astro
---
<div class="filter-group">
  <input 
    type="text" 
    id="libSearch" 
    class="input-filter" 
    placeholder="Search references by title, keyword, or author..." 
  />
  <select id="libFilter" class="select-filter">
    <option value="all">ALL CATEGORIES</option>
    <option value="acoustics">ACOUSTICS & DSP</option>
    <option value="pedagogy">PIANO MANUALS & PEDAGOGY</option>
    <option value="theory">MUSIC THEORY & COGNITION</option>
  </select>
</div>

<div id="libraryContainer" class="blueprint-grid">
  <slot />
</div>

<style>
  /* Filter Group Styles */
  .filter-group {
    display: flex;
    gap: 0.8rem;
    flex-wrap: wrap;
    margin: 1.2rem 0;
  }
  .input-filter {
    flex: 1;
    min-width: 220px;
    padding: 0.7rem 1rem;
    background-color: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    color: var(--text-main);
    font-size: 0.9rem;
    font-family: inherit;
    outline: none;
    transition: border-color 0.15s ease-in-out;
  }
  .input-filter:focus {
    border-color: var(--gold);
  }
  :root[data-theme="light"] .input-filter:focus {
    border-color: var(--sl-color-accent);
  }
  
  .select-filter {
    padding: 0.7rem 1rem;
    background-color: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    color: var(--text-main);
    font-size: 0.82rem;
    font-family: 'JetBrains Mono', monospace;
    cursor: pointer;
    outline: none;
    transition: border-color 0.15s ease-in-out;
    appearance: none;
    -webkit-appearance: none;
    padding-right: 2.2rem;
    
    background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%23C9A84C' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
    background-repeat: no-repeat;
    background-position: right 0.8rem center;
    background-size: 1.1rem;
  }
  
  :root[data-theme="light"] .select-filter {
    background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%239a7420' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
  }
  
  .select-filter:focus, .select-filter:hover {
    border-color: var(--gold);
  }
  
  :root[data-theme="light"] .select-filter:focus, 
  :root[data-theme="light"] .select-filter:hover {
    border-color: var(--sl-color-accent);
  }

  .select-filter option {
    background-color: var(--bg-dark) !important;
    color: var(--text-main) !important;
  }

  /* Grid Styles */
  .blueprint-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1rem;
    margin: 1.5rem 0 2rem;
    align-items: stretch !important;
  }

  /* Wipes adjacent margins on any generated children within the grid cell tracks */
  .blueprint-grid :global(*) {
    margin-top: 0 !important;
    margin-bottom: 0 !important;
  }

  /* Makes any enclosing MDX paragraphs act as transparent layout containers */
  .blueprint-grid > :global(p) {
    display: contents !important;
    margin: 0 !important;
    padding: 0 !important;
  }

  /* Hides any parsed empty sibling paragraph tags to prevent visual layout offsets */
  .blueprint-grid :global(p:empty) {
    display: none !important;
    margin: 0 !important;
    padding: 0 !important;
    height: 0 !important;
  }
</style>

<script>
  const searchInput = document.getElementById('libSearch') as HTMLInputElement | null;
  const filterSelect = document.getElementById('libFilter') as HTMLSelectElement | null;

  function filterLibrary(): void {
    if (!searchInput || !filterSelect) return;
    const query: string = searchInput.value.toLowerCase().trim();
    const category: string = filterSelect.value;
    const cards = document.querySelectorAll('.blueprint-card') as NodeListOf<HTMLElement>;

    cards.forEach((card: HTMLElement) => {
      const titleEl = card.querySelector('.blueprint-title');
      const descEl = card.querySelector('.blueprint-desc');
      if (!titleEl || !descEl) return;

      const title: string = titleEl.textContent?.toLowerCase() || '';
      const desc: string = descEl.textContent?.toLowerCase() || '';
      const cardCategory: string = card.getAttribute('data-category') || '';

      const matchesSearch: boolean = title.includes(query) || desc.includes(query);
      const matchesCategory: boolean = category === 'all' || cardCategory === category;

      if (matchesSearch && matchesCategory) {
        card.style.display = 'flex';
      } else {
        card.style.display = 'none';
      }
    });
  }

  if (searchInput && filterSelect) {
    searchInput.addEventListener('input', filterLibrary);
    filterSelect.addEventListener('change', filterLibrary);
  }
</script>
