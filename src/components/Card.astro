---
// src/components/Card.astro
import Icon from './Icon.astro';

/**
 * ### Card Component
 * 
 * A clean content tile featuring subtle shadow hover, transition parameters, and focus indicators.
 */
export interface Props {
  /** The primary title heading text populated inside the card. */
  title: string;
  /** 
   * Optional decorative subtitle displayed as monospaced uppercase metadata at the top of the card.
   * @default undefined
   */
  subtitle?: string; 
  /** 
   * Inserts a bold accent decorative border line on the selected edge.
   * @default "none"
   */
  border?: 'top' | 'left' | 'none'; 
  /** 
   * Theme styling preset applied to subtitles, decorative borders, and vector icons.
   * @default "gold"
   */
  accentColor?: 'gold' | 'rose' | 'none';
  /** 
   * Optional identifier name of an icon to display inside the card header.
   * @default "none"
   */
  icon?: 'info' | 'target' | 'warning' | 'play-box' | 'link' | 'speed-wall' | 'app-trap' | 'acronym-trap' | 'repeat' | 'moon' | 'retreat' | 'chevron-down' | 'star' | 'map' | 'none'; 
  /** 
   * Destination URL or path. Setting this renders an action anchor button at the bottom.
   * @default undefined
   */
  link?: string; 
  /** 
   * The button text displayed when a CTA link is configured.
   * @default "Open ↗"
   */
  buttonText?: string;
  /** 
   * Custom tag classification string used to filter elements in dynamic grids.
   * @default "none"
   */
  category?: 'acoustics' | 'pedagogy' | 'theory' | 'none'; 
}

const {
  title,
  subtitle,
  border = 'none',
  accentColor = 'gold',
  icon,
  link,
  buttonText = "Open ↗",
  category
} = Astro.props;
---

<div class:list={['unified-card', border !== 'none' ? `border-${border}` : '', accentColor]} data-category={category}>
  {subtitle && <div class="card-subtitle">{subtitle}</div>}
  
  <div class="card-header">
    {icon && icon !== 'none' && (
      <span class="card-icon" aria-hidden="true">
        <Icon name={icon} class="card-svg" />
      </span>
    )}
    <h4 class="card-title">{title}</h4>
  </div>

  <div class="card-content">
    <slot />
  </div>

  {link && (
    <a href={link} target="_blank" rel="noopener" class="btn-link">
      {buttonText}
    </a>
  )}
</div>

<style>
  .unified-card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius);
    padding: 1.4rem !important;
    box-sizing: border-box !important;
    display: flex !important;
    flex-direction: column !important;
    justify-content: flex-start !important;
    gap: 0.6rem !important;
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
    height: 100% !important;
    position: relative !important;
  }
  .unified-card:hover {
    transform: translateY(-2px);
    border-color: var(--gold);
    box-shadow: 0 4px 20px -2px rgba(201, 168, 76, 0.05);
  }
  :root[data-theme="light"] .unified-card:hover {
    border-color: var(--sl-color-accent);
    box-shadow: 0 4px 20px -2px rgba(154, 116, 32, 0.05);
  }

  .border-top { border-top-width: 3px !important; }
  .border-left { border-left-width: 3px !important; }

  /* Border Colors */
  .gold.border-top { border-top-color: var(--gold) !important; }
  :root[data-theme="light"] .gold.border-top { border-top-color: var(--sl-color-accent) !important; }
  .rose.border-top { border-top-color: var(--rose) !important; }

  .gold.border-left { border-left-color: var(--gold) !important; }
  :root[data-theme="light"] .gold.border-left { border-left-color: var(--sl-color-accent) !important; }
  .rose.border-left { border-left-color: var(--rose) !important; }

  .card-subtitle {
    font-family: 'JetBrains Mono', monospace !important;
    font-size: 0.6rem !important;
    letter-spacing: 0.12em !important;
    text-transform: uppercase !important;
    font-weight: 700 !important;
    margin-bottom: 0.1rem !important;
  }
  .gold .card-subtitle { color: var(--gold) !important; }
  :root[data-theme="light"] .gold .card-subtitle { color: var(--sl-color-accent) !important; }
  .rose .card-subtitle { color: var(--rose) !important; }

  .card-header {
    display: flex !important;
    flex-direction: column !important;
    align-items: flex-start !important;
    gap: 0.5rem !important;
    margin: 0 !important;
    padding: 0 !important;
  }
  
  .card-icon {
    display: block !important;
    flex-shrink: 0 !important;
  }
  .gold .card-icon { color: var(--gold) !important; }
  :root[data-theme="light"] .gold .card-icon { color: var(--sl-color-accent) !important; }
  .rose .card-icon { color: var(--rose) !important; }
  
  .card-icon :global(.card-svg) {
    width: 26px !important;
    height: 26px !important;
  }

  .card-title {
    font-family: 'Playfair Display', serif !important;
    font-size: 1.1rem !important;
    color: var(--text-main) !important;
    margin: 0 !important;
    font-weight: 700 !important;
    line-height: 1.3 !important;
  }

  .card-content {
    font-size: 0.88rem !important;
    line-height: 1.55 !important;
    color: var(--text-muted) !important;
    flex-grow: 1 !important;
  }
  .card-content :global(p) {
    margin: 0 !important;
    padding: 0 !important;
    font-size: inherit !important;
    line-height: inherit !important;
    color: inherit !important;
  }

  .btn-link {
    display: inline-block !important;
    text-align: center !important;
    background-color: var(--bg-card2) !important;
    border: 1px solid var(--border-color) !important;
    color: var(--text-main) !important;
    padding: 0.6rem 1rem !important;
    border-radius: 6px !important;
    font-size: 0.85rem !important;
    text-decoration: none !important;
    font-weight: 600 !important;
    transition: all 0.2s !important;
    cursor: pointer !important;
    width: 100% !important;
    box-sizing: border-box !important;
    margin-top: auto !important;
  }
  .btn-link:hover {
    background-color: var(--gold) !important;
    color: var(--sl-color-black) !important;
    border-color: var(--gold) !important;
    text-decoration: none !important;
  }
  :root[data-theme="light"] .btn-link:hover {
    background-color: var(--sl-color-accent) !important;
    color: var(--sl-color-white) !important;
    border-color: var(--sl-color-accent) !important;
  }
</style>
