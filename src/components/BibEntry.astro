---
interface Props {
  id: string;
}

const { id } = Astro.props;
---
<div id={id} class="bibliography-entry">
  <slot />
</div>

<style>
  .bibliography-entry {
    margin: 0 !important;
    padding: 0 !important;
    counter-increment: bib-counter; /* Increments the sequential numbering */
    scroll-margin-top: 6rem; /* Ensures sticky headers do not obscure the target when scrolled to */
  }
  
  /* Style the MDX-compiled paragraph inside our entry container */
  .bibliography-entry :global(p) {
    font-size: 0.9rem !important;
    line-height: 1.6 !important;
    margin-top: 0 !important;
    margin-bottom: 0.25rem !important; /* Tightened gap between references */
    color: var(--text-muted) !important;
    position: relative !important;
    padding-left: 2.4rem !important; /* Aligns all lines of text to the exact same starting column */
  }

  /* Absolute-positions the prefix to keep text alignment aligned */
  .bibliography-entry :global(p)::before {
    content: "[" counter(bib-counter) "]" !important;
    position: absolute !important;
    left: 0 !important;
    width: 2rem !important; /* Constrains the number width */
    white-space: nowrap !important; /* Prevents the closing bracket from wrapping onto a new line */
    text-align: right !important; /* Right-aligns numbers so [9] and [10] stack perfectly */
    font-family: var(--sl-font-mono) !important;
    font-size: 0.85rem !important;
    font-weight: 700 !important;
    color: var(--gold) !important;
  }

  :root[data-theme="light"] .bibliography-entry :global(p)::before {
    color: var(--sl-color-accent) !important;
  }

  .bibliography-entry:last-child :global(p) {
    margin-bottom: 0 !important;
  }
  
  .bibliography-entry :global(strong) {
    color: var(--text-main) !important;
  }

  /* Wikipedia-style target highlight animation */
  @keyframes target-flash {
    0% {
      background-color: var(--sl-color-accent-low);
      box-shadow: 0 0 0 6px var(--sl-color-accent-low);
      border-radius: 4px;
    }
    100% {
      background-color: transparent;
      box-shadow: 0 0 0 0 transparent;
    }
  }

  .bibliography-entry:target {
    animation: target-flash 2.5s cubic-bezier(0.25, 1, 0.5, 1);
  }
</style>
