---
// src/components/Grid.astro

/**
 * Defines an option inside the category selection dropdown list of interactive, searchable Grids.
 */
interface FilterOption {
  /**
   * The programmatic option identifier, matching card element classification attributes (e.g., `data-category`).
   */
  value: string;
  /**
   * The user-facing label text populated inside the select dropdown item.
   */
  label: string;
}

/**
 * Props for the Grid component.
 */
interface Props {
  /**
   * Force grid items into a strict column layout count (e.g., `cols={2}` for dual splits).
   * Overrides automatic layout wrapping. Mobile viewports will dynamically fall back to a single column.
   */
  cols?: number;
  /**
   * Minimum responsive item width before wrapping to another row. Ignored if `cols` is specified.
   * @default "320px"
   */
  minWidth?: string; 
  /**
   * Grid layout gap spacing.
   * @default "1.5rem"
   */
  gap?: string;
  /**
   * Activates interactive client-side query search bars and optional category filters.
   * @default false
   */
  searchable?: boolean;
  /**
   * Placeholder placeholder text populated inside search text input boxes.
   * @default "Search..."
   */
  placeholder?: string;
  /**
   * List of filter metadata categories. Only used if `searchable` is true.
   * @default []
   */
  filterOptions?: FilterOption[];
}

const {
  cols,
  minWidth = "320px",
  gap = "1.5rem",
  searchable = false,
  placeholder = "Search...",
  filterOptions = []
} = Astro.props;

const gridId = `grid-${Math.random().toString(36).substring(2, 11)}`;

// Compute CSS variables for clean integration with styles
const gridStyle = {
  gap,
  gridTemplateColumns: cols 
    ? `repeat(${cols}, minmax(0, 1fr))` 
    : `repeat(auto-fill, minmax(${minWidth}, 1fr))`
};
---

<div id={gridId} class:list={['grid-container', { 'cols-forced': !!cols }]} data-searchable={searchable ? "true" : "false"}>
  {searchable && (
    <div class="filter-group">
      <input 
        type="text" 
        class="input-filter" 
        placeholder={placeholder} 
      />
      {filterOptions.length > 0 && (
        <select class="select-filter">
          {filterOptions.map(option => (
            <option value={option.value}>{option.label}</option>
          ))}
        </select>
      )}
    </div>
  )}

  <div class="grid-layout" style={gridStyle}>
    <slot />
  </div>
</div>

<style>
  .grid-container {
    width: 100%;
    margin: 1.5rem 0 2.5rem;
  }
  .filter-group {
    display: flex;
    gap: 0.8rem;
    flex-wrap: wrap;
    margin-bottom: 1.2rem;
  }
  .input-filter {
    flex: 1;
    min-width: 220px;
    padding: 0.7rem 1rem;
    background-color: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    color: var(--text-main);
    font-size: 0.9rem;
    font-family: inherit;
    outline: none;
    transition: border-color 0.15s ease-in-out;
  }
  .input-filter:focus {
    border-color: var(--gold);
  }
  :root[data-theme="light"] .input-filter:focus {
    border-color: var(--sl-color-accent);
  }
  
  .select-filter {
    padding: 0.7rem 1rem;
    background-color: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    color: var(--text-main);
    font-size: 0.82rem;
    font-family: 'JetBrains Mono', monospace;
    cursor: pointer;
    outline: none;
    transition: border-color 0.15s ease-in-out;
    appearance: none;
    -webkit-appearance: none;
    padding-right: 2.2rem;
    
    background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%23C9A84C' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
    background-repeat: no-repeat;
    background-position: right 0.8rem center;
    background-size: 1.1rem;
  }
  
  :root[data-theme="light"] .select-filter {
    background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%239a7420' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
  }
  
  .select-filter:focus, .select-filter:hover {
    border-color: var(--gold);
  }
  
  :root[data-theme="light"] .select-filter:focus, 
  :root[data-theme="light"] .select-filter:hover {
    border-color: var(--sl-color-accent);
  }

  .select-filter option {
    background-color: var(--bg-dark) !important;
    color: var(--text-main) !important;
  }

  .grid-layout {
    display: grid !important;
    align-items: stretch !important;
  }

  /* Responsively override forced multi-column parameters on mobile */
  @media (max-width: 720px) {
    .cols-forced .grid-layout {
      grid-template-columns: 1fr !important;
    }
  }

  .grid-layout :global(*) {
    margin-top: 0 !important;
    margin-bottom: 0 !important;
  }
  .grid-layout > :global(p) {
    display: contents !important;
    margin: 0 !important;
    padding: 0 !important;
  }
  .grid-layout :global(p:empty) {
    display: none !important;
    margin: 0 !important;
    padding: 0 !important;
    height: 0 !important;
  }
</style>

{searchable && (
  <script is:inline define:vars={{ gridId }}>
    (function() {
      const container = document.getElementById(gridId);
      if (!container) return;
      
      const searchInput = container.querySelector('.input-filter');
      const filterSelect = container.querySelector('.select-filter');
      const cards = container.querySelectorAll('.resource-card');

      function performFilter() {
        const query = searchInput ? searchInput.value.toLowerCase().trim() : '';
        const category = filterSelect ? filterSelect.value : 'all';

        cards.forEach(card => {
          const text = card.textContent ? card.textContent.toLowerCase() : '';
          const cardCategory = card.getAttribute('data-category') || '';

          const matchesSearch = text.includes(query);
          const matchesCategory = category === 'all' || cardCategory === category;

          if (matchesSearch && matchesCategory) {
            card.style.removeProperty('display');
          } else {
            card.style.setProperty('display', 'none', 'important');
          }
        });
      }

      if (searchInput) searchInput.addEventListener('input', performFilter);
      if (filterSelect) filterSelect.addEventListener('change', performFilter);
    })();
  </script>
)}
