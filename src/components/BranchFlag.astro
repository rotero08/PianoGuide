---
// src/components/BranchFlag.astro

/**
 * Astro props interface for the BranchFlag component.
 */
export interface Props {
  /** The localized descriptive metadata content string written on the flag label. */
  text: string;
}
const { text } = Astro.props;
---
<span class="branch-flag">
  <span class="legend-dot opt"></span>
  {text}
</span>

<style>
  .branch-flag {
    display: inline-flex !important;
    align-items: center !important;
    gap: 0.45rem !important;
    font-family: 'JetBrains Mono', monospace !important;
    font-size: 0.66rem !important;
    letter-spacing: 0.04em !important;
    color: var(--rose) !important;
    border: 1px solid rgba(212, 118, 138, 0.4) !important;
    border-radius: 999px !important;
    padding: 0.3rem 0.75rem !important;
    margin-bottom: 1rem !important;
    width: max-content !important;
  }
  :root[data-theme="light"] .branch-flag {
    color: var(--badge-branch) !important;
    border-color: rgba(168, 80, 105, 0.4) !important;
  }
  .legend-dot {
    width: 11px !important;
    height: 11px !important;
    border-radius: 50% !important;
    flex-shrink: 0 !important;
  }
  .legend-dot.opt {
    background: transparent !important;
    border: 2px solid var(--rose) !important;
  }
  :root[data-theme="light"] .legend-dot.opt {
    border-color: var(--badge-branch) !important;
  }
</style>
